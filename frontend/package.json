{
  "name": "@work-frontier/control-room",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.23.1",
    "pnpm": "10.20.0"
  },
  "scripts": {
    "check": "biome lint src tests && tsc --noEmit",
    "fix": "biome lint --write src tests",
    "lint": "biome lint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "test:control-room": "vitest run tests/control-room",
    "test:product": "playwright test tests/product",
    "test:a11y": "playwright test tests/accessibility",
    "test:final": "vitest run && playwright test tests/product tests/accessibility"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@types/node": "22.18.0",
    "typescript": "5.9.2",
    "vitest": "3.2.4",
    "zod": "4.1.0",
    "@axe-core/playwright": "4.10.2",
    "@playwright/test": "1.55.1",
    "@types/react": "19.1.16",
    "@types/react-dom": "19.1.9",
    "vite": "7.1.7",
    "ts-prune": "0.10.3"
  },
  "dependencies": {
    "@tanstack/react-query": "5.90.5",
    "react": "19.1.1",
    "react-dom": "19.1.1"
  }
}
