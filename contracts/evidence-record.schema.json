{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://workfrontier.dev/schemas/evidence/v1.0.0",
  "title": "Work Frontier Evidence Record",
  "description": "Canonical schema for verification harness evidence records. Inspired by SARIF v2.1.0 patterns (invocation envelope, tool.driver, artifact.hashes, propertyBag). The property_bag field is an extension point for Todo 5 harness-specific data without requiring schema migration.",
  "type": "object",
  "required": [
    "schema_version",
    "harness_id",
    "status",
    "invocation",
    "tool"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for forward compatibility"
    },
    "harness_id": {
      "type": "string",
      "pattern": "^WF-HAR-[A-Z0-9]+(?:-[A-Z0-9]+)*$",
      "description": "Unique harness identifier from the authoritative registry (catalog + foundation local harnesses)",
      "examples": ["WF-HAR-PREFLIGHT-01", "WF-HAR-CONTRACT-03", "WF-HAR-OPS-02-L"]
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail", "skip"],
      "description": "Overall harness execution status"
    },
    "invocation": {
      "type": "object",
      "required": [
        "command",
        "exit_code",
        "start_time",
        "end_time",
        "duration_seconds"
      ],
      "properties": {
        "command": {
          "type": "string",
          "description": "Full command invoked by the harness",
          "minLength": 1
        },
        "exit_code": {
          "type": "integer",
          "description": "Process exit code"
        },
        "working_directory": {
          "type": "string",
          "description": "Working directory where command was executed"
        },
        "start_time": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when execution started"
        },
        "end_time": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp when execution completed"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0,
          "description": "Execution duration in seconds"
        }
      },
      "additionalProperties": false
    },
    "tool": {
      "type": "object",
      "required": [
        "name",
        "version",
        "commit_sha"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Tool name (e.g., pytest, mypy, ruff)",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "description": "Tool version string",
          "minLength": 1
        },
        "commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$",
          "description": "Git commit SHA (40-character hex) of the tested codebase"
        }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "description": "Files or resources examined or produced during execution",
      "default": [],
      "items": {
        "type": "object",
        "required": ["path"],
        "properties": {
          "path": {
            "type": "string",
            "description": "File path relative to repository root",
            "minLength": 1
          },
          "hashes": {
            "type": "object",
            "description": "Content hashes keyed by algorithm name (e.g., sha256)",
            "additionalProperties": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "results": {
      "type": "array",
      "description": "Individual test results or findings",
      "default": [],
      "items": {
        "type": "object",
        "required": ["kind", "passed"],
        "properties": {
          "kind": {
            "type": "string",
            "description": "Result type identifier",
            "minLength": 1
          },
          "passed": {
            "type": "boolean",
            "description": "Whether this specific result passed"
          },
          "detail": {
            "type": "string",
            "description": "Human-readable detail about the result"
          }
        },
        "additionalProperties": false
      }
    },
    "property_bag": {
      "type": "object",
      "description": "Extension point for harness-specific data. Todo 5 will add 62 more harnesses; this field enables extension without schema migration. Keys should be namespaced by harness (e.g., 'preflight.python_version', 'contract.service_name').",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
